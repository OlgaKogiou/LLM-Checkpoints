{
  "train_batch_size": 16,
  "train_micro_batch_size_per_gpu": 2,
  "gradient_accumulation_steps": 2,
  "zero_optimization": {
    "stage": 2,
    "allgather_partitions": false,
    "allgather_bucket_size": 2e8,
    "overlap_comm": false,
    "reduce_scatter": true,
    "reduce_bucket_size": 2e8,
    "contiguous_gradients": false
  },
    "optimizer": {
        "type": "AdamW",
        "params": {
        "lr": 2e-5,
        "betas": [0.9, 0.999],
        "eps": 1e-8,
        "weight_decay": 0.01
        }
    },
  "fp16": {
    "enabled": true
  },
    "tag_validation": "WARN"
}
