{
  "train_batch_size": 16,
  "train_micro_batch_size_per_gpu": 2,
  "gradient_accumulation_steps": 2,
  "zero_optimization": {
    "stage": 2
  },
    "optimizer": {
        "type": "AdamW",
        "params": {
        "lr": 2e-5,
        "betas": [0.9, 0.999],
        "eps": 1e-8,
        "weight_decay": 0.01
        }
    },
  "fp16": {
    "enabled": true
  },
  "checkpoint": {
    "engine": {
      "type": "file"
    },
    "writer": {
      "type": "MOCK",
      "decoupled": true,
      "num_writers": 4,
      "io_buffer_size": 1048576,
      "io_buffer_double": true,
      "show_statistics": true
    },
    "tag_validation": "WARN"
  }
}
